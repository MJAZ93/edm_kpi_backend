# Server
IP=0.0.0.0
PORT=8000
SCHEME=http
APP_NAME=KPI Platform

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=kpi_db

# Auth
JWT_PRIVATE_KEY=CHANGE_ME
TOKEN_TTL=86400

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# Storage
STORAGE_BACKEND=local
UPLOAD_DIR=./uploads

# S3 (only if STORAGE_BACKEND=s3)
AWS_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY=
AWS_SECRET_KEY=

# Performance
SCORE_EXECUTION_WEIGHT=0.6
SCORE_GOAL_WEIGHT=0.4
BLOCKER_SLA_DEFAULT_DAYS=3
